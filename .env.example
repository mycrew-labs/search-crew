# Search Crew 可选 API key
#
# 复制到 ~/.zshrc 并填入实际 key，然后 source ~/.zshrc。
# 完全不配置也可以用——会 fallback 到 Claude Code 内置 WebSearch / WebFetch。

# Jina AI（搜索 + 抓取 + 文档转换一体）
# 注册：https://jina.ai
export JINA_API_KEY=""

# Serper.dev（Google Search API）
# 注册：https://serper.dev
export SERPER_API_KEY=""

# GitHub API（代码 / repo / issue 搜索；未配置时匿名限流为每分钟 10 次）
# 创建 token：https://github.com/settings/tokens（只需 public_repo 权限）
export GITHUB_TOKEN=""

# ---- AI 综述 backend（任意一个未配也行；全未配 → 自动回落 jina） ----
# 由 fast-search / deep-search 在 query 未命中 ROUTING 硬规则时作为「先建立假设」的第一跳。
# 这里只放 API key（secret）；用哪个 model 在 ~/.config/search-crew/routing.yaml 的
# ai_summary.models 里按 backend × fast/deep 分层配置，不在 env 里写 model。
# 详见 ROUTING.md「AI 综述层」与 EXTENDING.md「AI 综述 backend」。

# grok（xAI Grok · Agent Tools API · web_search + x_search；偏英文舆论 / 实时讨论 / X 语境）
# 注册：https://console.x.ai（需绑卡充值）
export GROK_API_KEY=""

# doubao（火山方舟 · Responses API + 联网搜索；托管 Doubao / DeepSeek / Kimi，偏中文语境）
# 注册：https://www.volcengine.com/product/ark（需实名 + 在「开通管理」开通模型）
# 提示：routing.yaml 里的 model 要填【API model ID】（带日期小写，如 doubao-seed-2-0-pro-260215），
#       不是 console 显示名；列已开通 model：
#       curl -s https://ark.cn-beijing.volces.com/api/v3/models -H "Authorization: Bearer $DOUBAO_API_KEY"
export DOUBAO_API_KEY=""

# gemini（Google Gemini Search Grounding；偏全球综述 / 英文资料 / 通用检索）
# 注册：https://aistudio.google.com/app/apikey（免费 quota；大陆 IP 需代理）
export GEMINI_API_KEY=""
