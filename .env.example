# Search Crew 可选 API key
#
# 复制到 ~/.zshrc 并填入实际 key，然后 source ~/.zshrc。
# 完全不配置也可以用——会 fallback 到 Claude Code 内置 WebSearch / WebFetch。

# Jina AI（搜索 + 抓取 + 文档转换一体）
# 注册：https://jina.ai
export JINA_API_KEY=""

# Serper.dev（Google Search API）
# 注册：https://serper.dev
export SERPER_API_KEY=""

# GitHub API（代码 / repo / issue 搜索；未配置时匿名限流为每分钟 10 次）
# 创建 token：https://github.com/settings/tokens（只需 public_repo 权限）
export GITHUB_TOKEN=""
